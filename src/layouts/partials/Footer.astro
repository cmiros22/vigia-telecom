                            <path d="m7.187 9.466 4.166-2.483L7.187 4.5z" stroke="#90a1b9" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                    </a>
                    <a href="#" class="size-9 rounded-full flex items-center justify-center hover:bg-zinc-50 transition-colors">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 .5H4.667C2.365.5.5 2.353.5 4.638v8.276c0 2.285 1.865 4.138 4.167 4.138H13c2.301 0 4.167-1.853 4.167-4.138V4.638C17.167 2.353 15.3.5 13 .5" stroke="#90a1b9" stroke-linecap="round" stroke-linejoin="round"></path>
                            <path d="M12.167 8.325a3.3 3.3 0 0 1-.339 2.01 3.32 3.32 0 0 1-1.46 1.432 3.35 3.35 0 0 1-3.856-.616 3.29 3.29 0 0 1-.62-3.83c.315-.62.82-1.128 1.442-1.449a3.35 3.35 0 0 1 3.893.598c.505.502.835 1.152.94 1.855" stroke="#64748B" stroke-linecap="round" stroke-linejoin="round" ></path>
                        </svg>
                    </a>
                </div>
            </div>
            <div class="flex flex-wrap sm:flex-nowrap flex-1 justify-between gap-8 w-full max-w-3xl">
                <div>
                    <h3 class="text-base font-medium text-[#78D3EB] mb-6">Quienes Somos</h3>
                    <ul class="flex flex-col gap-3 list-none">
                      {
                        footer1.map((item, i) => (
                          <li class={footer1.length - 1 === i ? "mb-0" : "mb-0"}>
                            <a class="text-sm text-[#64748B] hover:text-zinc-700 transition-colors" href={item.url}>
                              {item.name}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                </div>
                <div>
                    <h3 class="text-base font-medium text-[#78D3EB] mb-6">Atención al cliente</h3>
                    <ul class="flex flex-col gap-3 list-none">
                      {
                        footer3.map((item, i) => (
                          <li class={footer1.length - 1 === i ? "mb-0" : "mb-0"}>
                            <a class="text-sm text-[#64748B] hover:text-zinc-700 transition-colors" href={item.url}>
                              {item.name}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                </div>
                <div>
                    <h3 class="text-base font-medium text-[#78D3EB] mb-6">Legales   </h3>
                    <ul class="flex flex-col gap-3 list-none">
                      {
                        footer2.map((item, i) => (
                          <li class={footer1.length - 1 === i ? "mb-0" : "mb-0"}>
                            <a class="text-sm text-[#64748B] hover:text-zinc-700 transition-colors" href={item.url} target={item.url.includes('.pdf') ? '_blank' : '_self'} rel={item.url.includes('.pdf') ? 'noopener noreferrer' : ''}>
                              {item.name}
                            </a>
                          </li>
                        ))
                      }
                    </ul>
                </div>
            </div>
        </div>
