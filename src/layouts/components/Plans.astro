<script is:inline>
    let isAnnual = true;

    const pricing = {
        basic: { monthly: 350, annual: 3780 },
        pro: { monthly: 450, annual: 4860 },
        enterprise: { monthly: 600, annual: 6480 }
    };

    function togglePricing(annual) {
        isAnnual = annual;

        // Format number with thousands separator
        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        // Update prices with formatting
        document.getElementById('basicPrice').textContent = formatNumber(isAnnual ? pricing.basic.annual : pricing.basic.monthly);
        document.getElementById('proPrice').textContent = formatNumber(isAnnual ? pricing.pro.annual : pricing.pro.monthly);
        document.getElementById('enterprisePrice').textContent = formatNumber(isAnnual ? pricing.enterprise.annual : pricing.enterprise.monthly);

        // Update period text
        const periodText = isAnnual ? '/anual' : '/mes';
        document.getElementById('basicPeriod').textContent = periodText;
        document.getElementById('proPeriod').textContent = periodText;
        document.getElementById('enterprisePeriod').textContent = periodText;

        // Update button styles
        const monthlyBtn = document.getElementById('monthlyBtn');
        const annuallyBtn = document.getElementById('annuallyBtn');

        if (isAnnual) {
            monthlyBtn.className = 'px-4 py-2 rounded-full text-sm cursor-pointer transition text-white transition';
            annuallyBtn.className = 'px-4 py-2 rounded-full text-sm cursor-pointer transition bg-[#00F5FF] hover:bg-[#00d4e6] text-gray-600 transition';
        } else {
            monthlyBtn.className = 'px-4 py-2 rounded-full text-sm cursor-pointer transition bg-[#00F5FF] hover:bg-[#00d4e6] bg-gradient-to-r from-[#00F5FF] to-[#007E94] text-[#0B0F14] transition';
            annuallyBtn.className = 'px-4 py-2 rounded-full text-sm cursor-pointer transition text-white transition';
        }
    }
</script>