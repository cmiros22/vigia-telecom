---
import Base from '@/layouts/Base.astro';
import CarouselParallax from '@/layouts/function-components/CarouselParallax';
import IntegrateMedia from "@/layouts/function-components/IntegrateMedia";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import PageHeader from "@/layouts/components/PageHeader.astro";
import { getEntry } from "astro:content";
import { Image } from 'astro:assets';
import Plans from "@/layouts/components/Plans.astro";
import Characteristics from "@/layouts/components/characteristics.astro";
import Promotional from "@/layouts/partials/Promotional.astro";

const categories = await getTaxonomy("integrations", "categories");
const integrations = await getSinglePage("integrations");

const how = await getEntry("how", "index");
const page_data = how ? {
  ...how.data,
  content: how.body,
} : {
  page_subtitle: "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
  page_title: "Lorem ipsum dolor sit amet",
  page_description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
};

