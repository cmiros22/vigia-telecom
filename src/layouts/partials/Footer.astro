---
import Logo from "public/images/logo.jpg";
import Social from "@/components/Social.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import social from "@/config/social.json";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from 'astro:assets';

const { footer1, footer2, offices } = menu;
const { copyright, location, email, phone, footer_description } = config.params;
---

<footer class="footer bg-[#181C21]">
  <div class="container text-header-color">
    <div class="row py-10">
        <div class="col-12 md:col-6 lg:col-3 pl-0 md:pl-20 pt-16 flex flex-col items-center md:items-start">
          <a href="/">
            <Image
            src={Logo}
            alt="Logo Black"
            class="-ml-4 w-[300px]"
          />
          </a>
          <p class="mt-6 text-black text-center md:text-left">
            {footer_description}
          </p>
          <div class="mt-8">
            <Social source={social} className="social-icons inline-flex space-x-2" />
          </div>
        </div>

        <div class="col-12 md:col-6 lg:col-3 pl-0 md:pl-20 pt-16 flex flex-col items-center md:items-start">
          <h6 class="text-header-color tracking-widest text-center md:text-left">Enlaces Rápidos</h6>
          <ul class="text-center md:text-left">
            {
              footer1.map((item, i) => (
                <li class={footer1.length - 1 === i ? "mb-0" : "mb-4"}>
                  <a class="text-bluePrimary-950 hover:underline" href={item.url}>
                    {item.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

      <div class="col-12 md:col-6 lg:col-span-2 pt-16 flex flex-col items-center md:items-start">
        <h6 class="text-header-color tracking-widest text-center md:text-left">Legales</h6>
        <ul class="lg:flex lg:flex-wrap text-center md:text-left">
          {
            footer2.map((item, i) => (
              <li class={footer2.length - 1 === i ? "mb-0" : "mb-4 lg:w-1/2"}>
                <a class="text-bluePrimary-950 hover:underline" href={item.url}>
                  {item.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- <div class="lg:col-span-2">
        <h3 class="text-lg font-semibold mb-4">Nuestras Oficinas</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {offices.map((office, index) => (
            <div class="flex items-start">
              {/* <MapPin class="w-5 h-5 text-gray-400 mr-2 mt-1 flex-shrink-0" /> */}
              <div>
                <h4 class="font-medium">{office.city}</h4>
                <p class="text-gray-400 text-sm">{office.address}</p>
              </div>
            </div>
          ))}
        </div>
      </div> -->

      <!-- <div class="col-12 md:col-6 lg:col-3 pt-16  flex flex-col items-center md:items-start">
        <h6 class="text-header-color tracking-widest text-center md:text-left">Nuestras oficinas</h6>
        <div class="space-y-4">
          {offices.map((office) => (
            <div class="flex items-start">
              {/* <MapPin class="w-5 h-5 text-gray-400 mr-2 mt-1 flex-shrink-0" /> */}
              <div>
                <p class="text-center md:text-left text-bluePrimary-950">{office.city}</p>
                <p class="text-center md:text-left text-gray-400">{office.address}</p>
              </div>
            </div>
          ))}
        </div>
        <!-- <p class="text-turquoise-blue font-normal text-center md:text-start">
          Receive the latest trends, insights, and expert tips delivered right to your inbox.
        </p> -->
        <!-- <form action="#">
          <div class="form-group">
            <input
              type="email"
              id="email"
              class="newsletter-field mt-6"
              placeholder="Your Email Address"
            />
          </div>
          
          <div class="flex flex-row justify-center md:justify-start">
            <input
              class="btn-turquoise-blue-hero font-normal mt-6 border-none "
              type="submit"
              value="Subscribe"
            />
            
          </div>
        </form>

      </div> -->
    </div>
  </div>

  <div class=" max-w-full bg-header-color">
    <div class="footer-copyright py-10 text-center md:flex md:flex-row md:justify-between container">
      <div>
        <p class="text-white mb-4 md:mb-0 md:mr-8" set:html={markdownify(copyright)} />
      </div>
      <div>
        <!-- <a class="text-white font-normal underline hover:text-turquoise-blue text-[15px] mb-4 md:mb-0 md:mr-8" href="/terms-and-conditions">Terms & Conditions</a> -->
        <a class="text-white font-normal underline hover:text-turquoise-blue text-[15px]" href="/aviso_de_privacidad">Aviso de Privacidad</a>
      </div>
      
    </div>
  </div>
</footer>
