---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import MapIcon from "/public/images/icons/map-pin.svg";
import EmailIcon from "/public/images/icons/email.svg";
import SupportIcon from "/public/images/icons/support.svg";
import Coverage from "@/layouts/components/coverage.astro";
---

<Base>
<section class="flex flex-row bg-[#0c0e13] md:flex-row pb-20 items-center justify-between mt-20 px-4 md:px-16 lg:px-24 xl:px-32">
    <div class="flex flex-col items-center md:items-start">
        <div class="flex flex-wrap items-center justify-center p-1.5 rounded-full border border-slate-600 text-white text-xs">
            <p class="-translate-x-2 text-[#6EDE74] ml-4">CANALES DE ATENCION</p>
        </div>
        <h1 class="text-center md:text-left text-5xl leading-[68px] md:text-6xl md:leading-[84px] font-medium max-w-xl text-slate-50">
            Conectemos con el futuro hoy.
        </h1>
    </div>
    <div class="flex flex-col justify-between md:max-w-xs" style="border-left: 2px solid #404658; padding-left: 1.5rem;">
        <p class="text-center md:text-left text-[#C4C6D0] text-sm font-light max-w-sm md:max-w-md mt-2">
            Estamos aquí para resolver tus dudas y asegurar que tu señal cinética nunca se detenga.
        </p>
    </div>
</section>

<section class="flex items-center bg-[#0c0e13] justify-center py-12 px-4">
    <div class="grid md:grid-cols-2 md:gap-10 lg:gap-20 max-w-7xl w-full items-center">
        <div class="p-5 bg-[#1D1D26] rounded-xl">
            <h1 class="text-lg font-semibold text-[#E2E2E9] text-center md:text-start mb-6 tracking-tight">
                Envíanos un mensaje
            </h1>
            <form>
                <div class="grid grid-cols-2 gap-4 mb-5">
                    <div>
                        <label class="block text-sm text-[#E2E2E9] mb-2">NOMBRE</label>
                        <input type="text" placeholder="Juan" class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm text-[#E2E2E9] mb-2">APELLIDO</label>
                        <input type="text" placeholder="Pérez" class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors" />  
                    </div>
                </div>

                <div class="mb-5">
                    <label class="block text-sm text-[#E2E2E9] mb-2">CORREO ELECTRONICO</label>
                    <input type="email" placeholder="ejemplo@company.com" class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors"/>
                </div>

                <div class="mb-5">
                    <label class="block text-sm text-gray-500 mb-2">TELEFONO</label>
                    <div class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors">
                        <input type="tel" placeholder="+52 342 123 4562" class="bg-[#33353B] flex-1 text-sm outline-none border-none" />
                    </div>
                </div>

                <div class="mb-5">
                    <label class="block text-sm text-[#E2E2E9] mb-2">ASUNTO</label>
                    <input type="email" placeholder="Soporte Técnico" class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors"/>
                </div>

                <div class="mb-5">
                    <label class="block text-sm text-[#E2E2E9] mb-2">TU MENSAJE</label>
                    <textarea placeholder="¿En qué podemos ayudarte?" rows="4" class="bg-[#33353B] w-full px-3 py-3 rounded-xl text-sm outline-none focus:border-[#6EDE74] transition-colors" ></textarea>
                </div>

                <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-[#6EDE74] to-[#006E20] text-white rounded-lg text-sm cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-[0_10px_20px_rgba(99,102,241,0.3)]" >
                    Enviar Consulta
                </button>
            </form>
        </div>

        <div class="rounded-3xl md:p-10 mt-10 gap-16 relative min-h-[662px] w-full max-w-full flex md:flex flex-col overflow-hidden">
            <div class="rounded-lg bg-[#004494] ">
                <div class="p-7">
                    <div class="flex flex-row gap-3 mb-6 items-center">
                        <div class="flex items-center justify-center p-2 bg-[#AEC6FF] bg-opacity-20 rounded-xl w-12 h-12 border border-[#AEC6FF]">
                            <SupportIcon width="32" height="32" class="Mision-icon" />
                        </div>
                        <p class="text-lg text-[#D8E2FF]">Centro de Soporte</p>
                    </div>
                    <p class="text-xs text-[#D8E2FF] font-light mb-3">Llámanos las 24 horas del día, los 7 días de las semanas.</p>
                    <p class="font-bold text-2xl text-[#D8E2FF]">+52 294 150 2001</p>
                </div>
            </div>
            <div class="rounded-lg bg-[#1D1D26] flex flex-col gap-5 p-7">
                <div class="flex flex-row gap-3 items-center">
                    <div class="flex items-center justify-center p-2 bg-[#AEC6FF] bg-opacity-20 rounded-xl w-12 h-12 border border-[#AEC6FF]">
                        <MapIcon width="32" height="32" class="Mision-icon" />
                    </div>
                    <div class="">
                        <p class="text-[#E2E2E9] text-sm mb-2">Dirección Física</p>
                        <p class="text-[#E2E2E9] text-xs font-light">Calle 19 de Marzo S/N, entre Leona Vicario y Manueal Ávila Camacho</p>
                        <p class="text-[#E2E2E9] text-xs font-light">Col. Centro, 45000 Santiago Tuxtla.</p>
                    </div>
                </div>
                <div class="flex flex-row gap-3 items-center">
                    <div class="flex items-center justify-center p-2 bg-[#AEC6FF] bg-opacity-20 rounded-xl w-12 h-12 border border-[#AEC6FF]">
                        <EmailIcon width="32" height="32" class="Mision-icon" />
                    </div>
                    <div class="">
                        <p class="text-[#E2E2E9] text-sm mb-2">Correo Electrónico</p>
                        <p class="text-[#E2E2E9] text-xs font-light">vigiatelecom@vigiatelecom.com</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<Coverage />